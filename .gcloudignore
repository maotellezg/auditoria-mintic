# .gcloudignore
# Prevent uploading heavy local dependencies and build outputs to Cloud Build

# Ignore node_modules
**/node_modules/
node_modules/
frontend/node_modules/
backend/node_modules/

# Ignore local builds
**/dist/
frontend/dist/

# Ignore git and config
.git/
.gitignore
.gcloudignore
.env
.env.local

# Ignore large test assets
anla_documento_test.png
